{
  "name": "@statuspageone/mcp",
  "version": "0.1.0",
  "description": "GetMonitor MCP server — connects AI assistants to your monitors, status pages, incidents, and on-call workflows",
  "license": "MIT",
  "type": "module",
  "bin": {
    "getmonitor-mcp": "./dist/stdio.js"
  },
  "main": "./dist/stdio.cjs",
  "module": "./dist/stdio.js",
  "exports": {
    ".": {
      "import": "./dist/stdio.js",
      "require": "./dist/stdio.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "express": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=20" },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
